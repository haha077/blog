{{- /* layouts/index.json */ -}}
[
  {{- $pages := where .Site.RegularPages "Type" "in" site.Params.mainSections -}}
  {{- range $index, $page := $pages -}}
    {{- if gt $index 0 }},{{ end }}
    {
      "title": {{ .Title | jsonify }},
      "description": {{ (.Params.description | default .Summary) | jsonify }},
      "content": {{ .Plain | jsonify }},
      "url": {{ .RelPermalink | jsonify }}
    }
  {{- end -}}
]
